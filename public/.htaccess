<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Desactivar el listado de directorios
  Options -Indexes

  # Evitar que Apache redirija automáticamente añadiendo una barra inclinada a carpetas reales (ej. /login -> /login/)
  DirectorySlash Off

  # Si la petición es un archivo físico real, se sirve directamente (imágenes, js, css, etc.)
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # Si NO es un archivo real (aunque exista una carpeta física con ese nombre, como /login), enviar a index.html
  RewriteRule . /index.html [L]
</IfModule>
